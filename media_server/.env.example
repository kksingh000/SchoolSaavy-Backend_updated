# Media Server Configuration
NODE_ENV=production

# Server Ports
HTTP_PORT=8000
RTMP_PORT=1935
INTERNAL_HTTP_PORT=8001

# Server Host (for production use your domain or IP)
SERVER_HOST=0.0.0.0
PUBLIC_HOST=localhost

# RTMP Configuration
RTMP_CHUNK_SIZE=60000
RTMP_GOP_CACHE=true
RTMP_PING=30
RTMP_PING_TIMEOUT=60

# HLS Configuration (for iOS/Safari)
HLS_ENABLED=true
HLS_SEGMENT_TIME=2
HLS_LIST_SIZE=3

# DASH Configuration (optional)
DASH_ENABLED=false

# Authentication
AUTH_ENABLED=true
AUTH_SECRET=schoolsaavy_media_secret_2025
# Backend API URL for stream validation
BACKEND_API_URL=http://app:8080/api
BACKEND_API_TOKEN=your_backend_api_token_here

# Stream Settings
MAX_STREAMS_PER_SCHOOL=10
STREAM_TIMEOUT=300000

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/media-server.log

# CORS Settings
CORS_ORIGINS=*
CORS_CREDENTIALS=true

# Storage
MEDIA_ROOT=./media
RECORDINGS_ENABLED=false
RECORDINGS_PATH=./recordings

# Performance
MAX_CONNECTIONS=1000
WORKER_THREADS=4
