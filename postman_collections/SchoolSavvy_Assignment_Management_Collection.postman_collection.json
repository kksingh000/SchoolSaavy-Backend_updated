							"raw": "{\n    \"class_id\": 1,\n    \"subject_id\": 4,\n    \"title\": \"Draw Your Pet\",\n    \"description\": \"Draw and color your favorite pet or an animal you would like as a pet\",\n    \"instructions\": \"Use crayons or colored pencils. Draw one animal. Color it nicely. Write the animal's name below your drawing.\",\n    \"type\": \"project\",\n    \"status\": \"published\",\n    \"assigned_date\": \"2025-07-27\",\n    \"due_date\": \"2025-08-05\",\n    \"max_marks\": 15,\n    \"allow_late_submission\": true,\n    \"grading_criteria\": \"Creativity: 5 marks, Coloring: 5 marks, Following instructions: 3 marks, Neatness: 2 marks\"\n}"
