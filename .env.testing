APP_NAME=Laravel
APP_ENV=testing
APP_KEY=base64:CBoIJUsAOzeG1YMJBDoxgoJFQr07qoXWP+yA91tNIsw=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=4

LOG_CHANNEL=stack
LOG_STACK=single
